# Slack App Credentials (Socket Mode)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# Groq API Key
GROQ_API_KEY=your-groq-api-key

# Datadog API Keys
DD_SITE=us5.datadoghq.com
DD_API_KEY=your-datadog-api-key
DD_APP_KEY=your-datadog-app-key

# GitHub Integration
GITHUB_REPO=your-github-username/slack-incident-agent
GITHUB_TOKEN=your-github-personal-access-token

# Jira Integration
JIRA_EMAIL=your-jira-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_DOMAIN=https://your-domain.atlassian.net
JIRA_PROJECT_KEY=SCRUM

# Comma-separated Slack User IDs to invite to the incident channel (e.g. U12345,U67890)
SECURITY_TEAM_USER_IDS=
